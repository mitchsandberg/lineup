<?xml version="1.0" encoding="utf-8" ?>
<component name="MainScene" extends="Scene">
    <interface>
        <function name="handleDeepLink" />
    </interface>

    <script type="text/brightscript" uri="MainScene.brs" />
    <script type="text/brightscript" uri="pkg:/source/utils.brs" />
    <script type="text/brightscript" uri="pkg:/source/config.brs" />

    <children>
        <!-- Guide screen -->
        <Rectangle
            id="guidePanel"
            width="1280"
            height="720"
            color="#0D1117"
        >
            <Label
                id="titleLabel"
                text="Lineup"
                translation="[60, 25]"
                font="font:LargeBoldSystemFont"
                color="#FFFFFF"
            />
            <Label
                id="dateLabel"
                translation="[1060, 33]"
                font="font:SmallSystemFont"
                color="#8B95A5"
                horizAlign="right"
                width="180"
            />

            <!-- Tab indicator -->
            <Label
                id="tabGuideLabel"
                text="Guide"
                translation="[60, 72]"
                font="font:SmallBoldSystemFont"
                color="#FFFFFF"
            />
            <Label
                id="tabSettingsLabel"
                text="Settings"
                translation="[160, 72]"
                font="font:SmallSystemFont"
                color="#8B95A5"
            />

            <!-- Sport filter bar -->
            <ButtonGroup
                id="sportFilter"
                translation="[60, 105]"
                textColor="#8B95A5"
                focusedTextColor="#FFFFFF"
            />

            <!-- Clipping region for scrollable events -->
            <Rectangle
                id="eventsClip"
                translation="[0, 155]"
                width="1280"
                height="565"
                color="#00000000"
                clippingRect="[0, 0, 1280, 565]"
            >
                <Group id="eventsGroup" translation="[60, 0]" />
            </Rectangle>

            <!-- Loading label -->
            <Label
                id="loadingLabel"
                text="Loading sports..."
                translation="[540, 360]"
                font="font:MediumSystemFont"
                color="#8B95A5"
                visible="true"
            />

            <!-- Empty state -->
            <Label
                id="emptyLabel"
                text="No live or upcoming events"
                translation="[440, 360]"
                font="font:MediumSystemFont"
                color="#8B95A5"
                visible="false"
            />
        </Rectangle>

        <!-- Settings screen (hidden by default) -->
        <Rectangle
            id="settingsPanel"
            width="1280"
            height="720"
            color="#0D1117"
            visible="false"
        >
            <Label
                id="settingsTitleLabel"
                text="Lineup"
                translation="[60, 25]"
                font="font:LargeBoldSystemFont"
                color="#FFFFFF"
            />
            <Label
                id="settingsTabGuide"
                text="Guide"
                translation="[60, 72]"
                font="font:SmallSystemFont"
                color="#8B95A5"
            />
            <Label
                id="settingsTabSettings"
                text="Settings"
                translation="[160, 72]"
                font="font:SmallBoldSystemFont"
                color="#FFFFFF"
            />
            <Label
                id="settingsHeading"
                text="Streaming Services"
                translation="[60, 115]"
                font="font:MediumBoldSystemFont"
                color="#FFFFFF"
            />
            <Label
                id="settingsSubheading"
                text="Select the services you subscribe to"
                translation="[60, 148]"
                font="font:SmallSystemFont"
                color="#8B95A5"
            />

            <Group id="serviceListGroup" translation="[60, 185]" />
        </Rectangle>

        <EventFetchTask id="fetchTask" />
    </children>
</component>
